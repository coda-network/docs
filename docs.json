{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CODA",
  "colors": {
    "primary": "#1A66E5",
    "light": "#4684EE",
    "dark": "#1453C4"
  },
  "favicon": {
    "light": "/images/logo_sqr.svg",
    "dark": "/images/logo_sqr.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Product",
        "pages": [
          "index",
          "how-coda-works"
        ]
      },
      {
        "group": "For institutions",
        "pages": [
          "institutional-workflows",
          "control-and-responsibility"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "href": "https://www.codanetwork.io",
          "icon": "newspaper"
        }
      ]
    },
    "groups": []
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Request Access",
      "href": "https://www.codanetwork.io/#request-access"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/coda-network"
    }
  },
  "background": {
    "color": {
      "light": "#F6F8FB",
      "dark": "#04070F"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "logo": {
    "light": "/images/logo_dark_rec.svg",
    "dark": "/images/logo_dark_rec.svg"
  }
}
